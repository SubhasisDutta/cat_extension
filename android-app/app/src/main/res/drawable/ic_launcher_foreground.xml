<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive-icon foreground. 108dp canvas, 72dp safe zone centered.
     A simplified, chunky version of the cat in CatArt.svgMarkup() — the
     full SVG is too detailed for an icon at small sizes. Kept readable
     at 48dp. Same palette as the SVG; same annoyed half-lid eyes. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Body (big oval, bottom-heavy) -->
    <path
        android:fillColor="#ef8b2a"
        android:strokeColor="#7a3a08"
        android:strokeWidth="2.5"
        android:pathData="M54,74 m-26,0 a26,18 0 1,0 52,0 a26,18 0 1,0 -52,0" />

    <!-- Belly highlight -->
    <path
        android:fillColor="#ffe6c4"
        android:pathData="M54,80 m-16,0 a16,9 0 1,0 32,0 a16,9 0 1,0 -32,0" />

    <!-- Front paws -->
    <path
        android:fillColor="#ef8b2a"
        android:strokeColor="#7a3a08"
        android:strokeWidth="2"
        android:pathData="M40,90 m-5,0 a5,3 0 1,0 10,0 a5,3 0 1,0 -10,0" />
    <path
        android:fillColor="#ef8b2a"
        android:strokeColor="#7a3a08"
        android:strokeWidth="2"
        android:pathData="M68,90 m-5,0 a5,3 0 1,0 10,0 a5,3 0 1,0 -10,0" />

    <!-- Head (centered above body) -->
    <path
        android:fillColor="#ffb86b"
        android:strokeColor="#7a3a08"
        android:strokeWidth="2.5"
        android:pathData="M54,42 m-19,0 a19,16 0 1,0 38,0 a19,16 0 1,0 -38,0" />

    <!-- Left ear -->
    <path
        android:fillColor="#ef8b2a"
        android:strokeColor="#7a3a08"
        android:strokeWidth="2"
        android:pathData="M40,32 L33,20 L48,28 Z" />
    <!-- Right ear -->
    <path
        android:fillColor="#ef8b2a"
        android:strokeColor="#7a3a08"
        android:strokeWidth="2"
        android:pathData="M68,32 L75,20 L60,28 Z" />

    <!-- Inner ear pink -->
    <path
        android:fillColor="#ffb1b1"
        android:pathData="M42,30 L37,23 L46,27 Z" />
    <path
        android:fillColor="#ffb1b1"
        android:pathData="M66,30 L71,23 L62,27 Z" />

    <!-- Cheeks -->
    <path
        android:fillColor="#ffd6a8"
        android:pathData="M45,46 m-5,0 a5,3 0 1,0 10,0 a5,3 0 1,0 -10,0" />
    <path
        android:fillColor="#ffd6a8"
        android:pathData="M63,46 m-5,0 a5,3 0 1,0 10,0 a5,3 0 1,0 -10,0" />

    <!-- Annoyed half-lid eyes (curved arcs) -->
    <path
        android:fillColor="#1f1f1f"
        android:pathData="M42,40 q3,-3 6,0 q-3,2 -6,0 z" />
    <path
        android:fillColor="#1f1f1f"
        android:pathData="M60,40 q3,-3 6,0 q-3,2 -6,0 z" />

    <!-- Nose (small triangle) -->
    <path
        android:fillColor="#7a3a08"
        android:pathData="M52,49 L56,49 L54,52 Z" />

    <!-- Mouth (flat, unimpressed) -->
    <path
        android:strokeColor="#1f1f1f"
        android:strokeWidth="1.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M50,55 q4,2 8,0" />
</vector>
