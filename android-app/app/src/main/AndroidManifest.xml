<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- The cat draws over other apps during a break. User must grant this
         once via Settings > Apps > Special access > Display over other apps. -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Foreground service keeps the timer alive while the screen is off. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- Pre-break warning notification (Android 13+). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Re-arm the timer after device reboot. -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Exact alarms: phase boundaries must fire on time. -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />

    <application
        android:label="Fat Orange Cat"
        android:allowBackup="false"
        android:supportsRtl="true"
        tools:targetApi="35">

        <!-- MainActivity (Compose settings UI) lands in PR #2.
             Manifest is intentionally empty until then so the project still
             builds as an installable APK skeleton. -->
    </application>
</manifest>
